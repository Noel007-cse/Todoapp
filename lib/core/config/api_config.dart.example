// lib/core/config/api_config.dart.example
//
// Copy this file to api_config.dart and fill in your API keys.
// DO NOT commit api_config.dart — it is gitignored.

class ApiConfig {
  ApiConfig._();

  /// Groq API key — get yours at https://console.groq.com
  static const String groqApiKey = String.fromEnvironment(
    'GROQ_API_KEY',
    defaultValue: 'YOUR_GROQ_API_KEY_HERE',
  );

  static const String groqBaseUrl =
      'https://api.groq.com/openai/v1/chat/completions';

  static const String groqModel = 'llama-3.3-70b-versatile';
}
